// ─── LazyPrep Prisma Schema ───
// Generic preparation engine — supports unlimited certifications
// CCNA is the first content pack, not the core identity

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Prisma 7: connection URLs live in prisma.config.ts (CLI) and the
  // driver adapter in src/lib/prisma.ts (runtime).
  provider = "postgresql"
}

// ═══════════════════════════════════════════
// AUTH (Better Auth managed tables)
// These four models are required by Better Auth's Prisma adapter.
// We extend with a custom Profile for gamification.
// ═══════════════════════════════════════════

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions Session[]
  accounts Account[]
  profile  Profile?

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

model Profile {
  id            String    @id @default(cuid())
  userId        String    @unique // references Better Auth user.id
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName   String?
  avatarUrl     String?
  timezone      String    @default("UTC") // IANA tz, e.g. "Asia/Kolkata"; day boundaries computed here
  xp            Int       @default(0)
  level         Int       @default(1)
  currentStreak Int       @default(0)
  longestStreak Int       @default(0)
  lastStudyDate DateTime?
  onboardedAt   DateTime? // null = hasn't completed the first-run tour yet
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  enrollments      Enrollment[]
  progress         Progress[]
  questionAttempts QuestionAttempt[]
  studySessions    StudySession[]
  bookmarks        Bookmark[]
  ownedCourses     Course[]
  aiKey            AiKey?
  flashcardReviews FlashcardReview[]
  ownedFlashcards  Flashcard[]       @relation("ProfileFlashcards")
  mockTests        MockTest[]
  questionReviews  QuestionReview[]
  studyPlans       StudyPlan[]
}

// ═══════════════════════════════════════════
// AI CREDENTIALS (BYO key — encrypted at rest)
// The plaintext key is NEVER stored or returned to the client.
// ═══════════════════════════════════════════

model AiKey {
  id         String   @id @default(cuid())
  profileId  String   @unique
  provider   String   @default("openrouter")
  baseUrl    String   @default("https://openrouter.ai/api/v1")
  model      String   @default("openai/gpt-4o-mini")
  ciphertext String // AES-256-GCM ciphertext (base64)
  iv         String // base64
  authTag    String // base64
  last4      String // last 4 chars for display, e.g. "a1b4"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════════
// COURSE HIERARCHY
// Course → Module → Chapter → Lesson
// The engine never knows what "CCNA" is
// ═══════════════════════════════════════════

model Course {
  id          String   @id @default(cuid())
  slug        String   @unique // "ccna", "security-plus", "aws-saa"
  title       String
  description String?
  imageUrl    String?
  category    String   @default("certification") // certification | college | competitive | custom
  published   Boolean  @default(false)
  ownerId     String? // null = curated/global (e.g. seeded CCNA); set = user-generated
  aiGenerated Boolean  @default(false)
  adaptive    Boolean  @default(false) // phased mastery course (Foundation→Intermediate→Advanced)
  parentId    String? // set when this course was spawned as a deep-dive of another
  aiContext   Json? // the questionnaire answers, used as context when generating lessons
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner       Profile?     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  parent      Course?      @relation("CourseDeepDives", fields: [parentId], references: [id], onDelete: SetNull)
  deepDives   Course[]     @relation("CourseDeepDives")
  modules     Module[]
  enrollments Enrollment[]
  questions   Question[]
  flashcards  Flashcard[]
  mockTests   MockTest[]
  studyPlans  StudyPlan[]

  @@index([ownerId])
  @@index([parentId])
}

// ═══════════════════════════════════════════
// STUDY PLAN (per-user, per-course exam-date + habit engine)
// ═══════════════════════════════════════════

model StudyPlan {
  id        String   @id @default(cuid())
  profileId String
  courseId  String
  examDate  DateTime? @db.Date // target exam date; null = no date set yet
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  course  Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([profileId, courseId])
  @@index([profileId])
}

model Enrollment {
  id         String   @id @default(cuid())
  profileId  String
  courseId    String
  enrolledAt DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  course  Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([profileId, courseId])
  @@index([profileId])
}

model Module {
  id       String @id @default(cuid())
  courseId  String
  title    String
  slug     String
  order    Int

  // Adaptive-course phase fields (null/false for flat courses):
  phaseLevel       String? // "foundation" | "intermediate" | "advanced"
  locked           Boolean @default(false) // locked until the previous checkpoint is passed
  contentGenerated Boolean @default(false) // whether this phase's lessons exist yet

  course     Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  chapters   Chapter[]
  checkpoint Checkpoint?

  @@unique([courseId, slug])
  @@unique([courseId, order])
}

// ═══════════════════════════════════════════
// CHECKPOINTS (per-phase mastery mocktest — adaptive courses)
// Adaptive courses are single-owner, so pass state lives on the checkpoint.
// ═══════════════════════════════════════════

model Checkpoint {
  id            String   @id @default(cuid())
  moduleId      String   @unique
  passThreshold Int      @default(70) // % needed to pass
  passed        Boolean  @default(false)
  bestScore     Int      @default(0) // best % achieved
  attempts      Int      @default(0)
  generated     Boolean  @default(false) // questions generated yet?
  weakTopics    String[] @default([]) // topics missed — fed into next phase generation
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  module    Module               @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  questions CheckpointQuestion[]
}

model CheckpointQuestion {
  id           String @id @default(cuid())
  checkpointId String
  topic        String
  difficulty   String
  text         String
  options      Json
  correctIdx   Int
  explanation  String

  checkpoint Checkpoint @relation(fields: [checkpointId], references: [id], onDelete: Cascade)

  @@index([checkpointId])
}

model Chapter {
  id       String @id @default(cuid())
  moduleId String
  title    String
  slug     String
  order    Int

  module  Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@unique([moduleId, slug])
  @@unique([moduleId, order])
}

model Lesson {
  id               String @id @default(cuid())
  chapterId        String
  title            String
  slug             String
  content          String // Markdown stored in database
  order            Int
  estimatedMinutes Int    @default(10)

  chapter  Chapter    @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  progress Progress[]

  @@unique([chapterId, slug])
  @@unique([chapterId, order])
}

// ═══════════════════════════════════════════
// PROGRESS TRACKING
// ═══════════════════════════════════════════

model Progress {
  id             String    @id @default(cuid())
  profileId      String
  lessonId       String
  completed      Boolean   @default(false)
  completedAt    DateTime?
  lastAccessedAt DateTime  @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  lesson  Lesson  @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([profileId, lessonId])
  @@index([profileId])
}

// ═══════════════════════════════════════════
// QUESTIONS (MCQ)
// ═══════════════════════════════════════════

model Question {
  id          String   @id @default(cuid())
  courseId     String
  topic       String
  difficulty  String   // "easy" | "medium" | "hard"
  text        String
  options     Json     // string[]
  correctIdx  Int
  explanation String
  tags        String[] // e.g., ["subnetting", "vlsm", "ipv4"]

  course   Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  attempts QuestionAttempt[]
  reviews  QuestionReview[]

  @@index([courseId, topic])
  @@index([courseId, difficulty])
}

// ═══════════════════════════════════════════
// SPACED REPETITION FOR MCQs (SM-2 per-user question state)
// Mirrors FlashcardReview: every practice answer schedules the question so
// weak/missed questions resurface on the right day.
// ═══════════════════════════════════════════

model QuestionReview {
  id             String   @id @default(cuid())
  profileId      String
  questionId     String
  easeFactor     Float    @default(2.5)
  interval       Int      @default(0) // days until next review
  repetitions    Int      @default(0)
  lapses         Int      @default(0)
  dueDate        DateTime @default(now())
  lastReviewedAt DateTime @default(now())

  profile  Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([profileId, questionId])
  @@index([profileId, dueDate])
}

model QuestionAttempt {
  id          String   @id @default(cuid())
  profileId   String
  questionId  String
  selectedIdx Int
  correct     Boolean
  createdAt   DateTime @default(now())

  profile  Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([profileId, correct])
  @@index([profileId, questionId])
}

// ═══════════════════════════════════════════
// FLASHCARDS
// ═══════════════════════════════════════════

model Flashcard {
  id          String   @id @default(cuid())
  courseId    String
  front       String
  back        String
  topic       String
  tags        String[]
  ownerId     String? // null = curated (visible to everyone); set = private, AI-generated for one user
  aiGenerated Boolean  @default(false)

  course  Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  owner   Profile?          @relation("ProfileFlashcards", fields: [ownerId], references: [id], onDelete: Cascade)
  reviews FlashcardReview[]

  @@index([courseId, topic])
  @@index([courseId, ownerId])
}

// ═══════════════════════════════════════════
// SPACED REPETITION (SM-2 per-user card state)
// ═══════════════════════════════════════════

model FlashcardReview {
  id             String   @id @default(cuid())
  profileId      String
  flashcardId    String
  easeFactor     Float    @default(2.5)
  interval       Int      @default(0) // days until next review
  repetitions    Int      @default(0)
  lapses         Int      @default(0)
  dueDate        DateTime @default(now())
  lastReviewedAt DateTime @default(now())

  profile   Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  flashcard Flashcard @relation(fields: [flashcardId], references: [id], onDelete: Cascade)

  @@unique([profileId, flashcardId])
  @@index([profileId, dueDate])
}

// ═══════════════════════════════════════════
// MOCK TESTS (AI-generated timed exams, per-user)
// Generated with the user's BYO key from a course's lesson coverage.
// Answers are graded server-side in one submit (exam semantics).
// ═══════════════════════════════════════════

model MockTest {
  id              String   @id @default(cuid())
  profileId       String
  courseId        String
  title           String
  difficulty      String   @default("mixed") // easy | medium | hard | mixed
  durationMinutes Int      @default(20)
  createdAt       DateTime @default(now())

  profile   Profile            @relation(fields: [profileId], references: [id], onDelete: Cascade)
  course    Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions MockTestQuestion[]
  attempts  MockTestAttempt[]

  @@index([profileId, courseId])
}

model MockTestQuestion {
  id          String @id @default(cuid())
  testId      String
  order       Int
  topic       String
  difficulty  String
  text        String
  options     Json // string[]
  correctIdx  Int
  explanation String

  test MockTest @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@unique([testId, order])
}

model MockTestAttempt {
  id          String    @id @default(cuid())
  testId      String
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  score       Int       @default(0) // percent
  correct     Int       @default(0)
  total       Int       @default(0)
  answers     Json      @default("[]") // (number|null)[] indexed by question order

  test MockTest @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@index([testId])
}

// ═══════════════════════════════════════════
// STUDY SESSIONS (Heatmap + Analytics)
// ═══════════════════════════════════════════

model StudySession {
  id                String   @id @default(cuid())
  profileId         String
  date              DateTime @db.Date
  studyMinutes      Int      @default(0)
  questionsAnswered Int      @default(0)
  correctAnswers    Int      @default(0)
  lessonsCompleted  Int      @default(0)
  flashcardsReviewed Int     @default(0)
  xpEarned          Int      @default(0)

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, date])
  @@index([profileId])
}

// ═══════════════════════════════════════════
// BOOKMARKS
// ═══════════════════════════════════════════

model Bookmark {
  id         String   @id @default(cuid())
  profileId  String
  targetType String   // "question" | "flashcard" | "lesson"
  targetId   String
  createdAt  DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, targetType, targetId])
  @@index([profileId, targetType])
}
