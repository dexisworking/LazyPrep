# ─── Database (Neon Postgres) ───
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# ─── Auth (Better Auth) ───
BETTER_AUTH_SECRET="generate-a-random-32-char-secret-here"
BETTER_AUTH_URL="http://localhost:3000"

# ─── Encryption (AES-256-GCM for user AI API keys) ───
# 32-byte key, base64-encoded. Generate with: openssl rand -base64 32
ENCRYPTION_KEY="generate-a-32-byte-base64-key-here"

# ─── Google OAuth ───
# Create at https://console.cloud.google.com → APIs & Services → Credentials
# → OAuth client ID (Web application).
# Authorized redirect URI: {BETTER_AUTH_URL}/api/auth/callback/google
#   dev:  http://localhost:3000/api/auth/callback/google
# Leave blank to disable Google sign-in (the button is hidden automatically).
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Resend (Transactional Email — enables email verification) ───
# Get a key at https://resend.com. When set, new email/password signups must
# verify their email before signing in. Leave blank to disable verification.
RESEND_API_KEY=""
# Sender address. For production, verify a domain in Resend and use it here.
# The default onboarding sender only delivers to your own Resend account email.
EMAIL_FROM="LazyPrep <onboarding@resend.dev>"
# Inbox that receives in-app feedback notifications (leave blank to disable).
FEEDBACK_EMAIL=""

# ─── Cloudflare R2 (File Storage) ───
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="lazyprep"
R2_PUBLIC_URL=""

# ─── App ───
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Error monitoring (Sentry — optional, inert until DSN is set) ───
# Create a project at sentry.io, then set both the server and public DSN.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
# Only needed to upload source maps at build time (better stack traces):
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
