# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — everything ignored except the placeholder template, which
# contributors need in order to configure a local install.
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Prisma generated client
/node_modules/.prisma
.claude/launch.json

# Sentry Config File
.env.sentry-build-plugin

# Android / Bubblewrap TWA
android/*.keystore
android/*.jks
android/app-*.apk
android/app-*.aab
android/.build/
# Gradle build output and machine-local SDK path
android/.gradle/
android/build/
android/app/build/
android/local.properties
# Bubblewrap writes signing-key passwords here when --skipSigning is not used
android/keystore.properties
# one-off local scripts and DB snapshots (demo-data seeding)
scripts/tmp-*
# marketing workfiles — captures contain the owner's real account state
docs/marketing/captures/
docs/marketing/lazyprep-captures.zip
